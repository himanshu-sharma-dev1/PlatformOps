logging {
  level  = "info"
  format = "logfmt"
}

local.file_match "platformops_logs" {
  path_targets = [
    { "__path__" = "/var/log/alloy/*.log", "job" = "platformops-alloy" },
  ]
}

loki.source.file "platformops_logs" {
  targets    = local.file_match.platformops_logs.targets
  forward_to = [loki.write.local.receiver]
}

loki.write "local" {
  endpoint {
    url = "http://localhost:3100/loki/api/v1/push"
  }
}
